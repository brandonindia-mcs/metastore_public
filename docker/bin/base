#!/bin/bash

if [ -z "$SECURE_ASSETS" ];then echo SECURE_ASSETS not set && exit 1;fi
if [[ "$1" = "-d" ]];then # BUILD base-d DOCKERFILE
cat $SECURE_ASSETS/../docker.master/Dockerfile.user.base-d >$SECURE_ASSETS/../Dockerfile.user\
  && image -t base-d user || exit 1
else
# cat $SECURE_ASSETS/../docker.master/Dockerfile.user.base-d >$SECURE_ASSETS/../Dockerfile.user\
#   && image $@ -t base-d user || exit 1
cat $SECURE_ASSETS/../docker.master/Dockerfile.user.base >$SECURE_ASSETS/../Dockerfile.user\
  && image $@ -t base user || exit 1
echo 'ENTRYPOINT ["/entrypoint.sh"]' >>$SECURE_ASSETS/../Dockerfile.user\
  && image $@ -t base-vol user || exit 1
fi

echo script \`base\` completed at $(date)
